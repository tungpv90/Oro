# ─── Environment ────────────────────────
NODE_ENV=development

# ─── PostgreSQL ─────────────────────────
POSTGRES_DB=oro
POSTGRES_USER=oro
POSTGRES_PASSWORD=oro_secret

# ─── MinIO ──────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=oro-media

# ─── JWT ────────────────────────────────
JWT_SECRET=change_me_in_production_use_random_64_chars
JWT_REFRESH_SECRET=change_me_refresh_in_production_use_random_64_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Frontend ───────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=change_me_nextauth_secret

# ─── Redis ──────────────────────────────
REDIS_URL=redis://localhost:6379
